{
  "version": 1,
  "policySet": "component-policies",
  "rules": [
    {
      "id": "BTN_RULE_001",
      "scope": "button.behavior",
      "when": {
        "action": "definedByDynamicAction"
      },
      "forbid": [
        "warnOnUnsavedChanges"
      ],
      "severity": "error",
      "message": "warnOnUnsavedChanges is not supported when action is definedByDynamicAction",
      "autofix": {
        "remove": [
          "warnOnUnsavedChanges"
        ]
      }
    },
    {
      "id": "BTN_RULE_002",
      "scope": "button.behavior",
      "forbidValues": {
        "action": [
          "redirectAnotherApp"
        ]
      },
      "allowValues": {
        "action": [
          "submitPage",
          "redirectThisApp",
          "redirectOtherApp",
          "definedByDynamicAction",
          "triggerAction",
          "menu"
        ]
      },
      "severity": "error",
      "message": "Use action redirectOtherApp instead of redirectAnotherApp."
    },
    {
      "id": "PAGE_RULE_001",
      "scope": "page.appearance",
      "when": {
        "pageMode": "modalDialog"
      },
      "require": [
        "dialogTemplate"
      ],
      "forbidValues": {
        "dialogTemplate": [
          "@/modal"
        ]
      },
      "allowValues": {
        "dialogTemplate": [
          "@/modal-dialog",
          "@/drawer",
          "@/wizard-modal-dialog"
        ]
      },
      "severity": "error",
      "message": "For modalDialog pages, dialogTemplate must be one of @/modal-dialog, @/drawer, or @/wizard-modal-dialog."
    },
    {
      "id": "DA_RULE_001",
      "scope": "dynamicAction.action.settings",
      "when": {
        "action": "setValue"
      },
      "require": [
        "type"
      ],
      "forbid": [
        "setType"
      ],
      "severity": "error",
      "message": "setValue must use settings.type and must not use setType."
    },
    {
      "id": "DA_RULE_002",
      "scope": "dynamicAction.action.settings",
      "when": {
        "action": "setValue"
      },
      "forbidValues": {
        "type": [
          "sqlStatement"
        ]
      },
      "allowValues": {
        "type": [
          "static",
          "sqlQuery",
          "plsqlFunctionBody",
          "javaScriptExpression"
        ]
      },
      "severity": "error",
      "message": "setValue settings.type must be one of static, sqlQuery, plsqlFunctionBody, or javaScriptExpression."
    },
    {
      "id": "DA_RULE_003",
      "scope": "dynamicAction.action",
      "when": {
        "action": "setValue"
      },
      "conditionalRequire": {
        "type=sqlQuery": [
          "sqlQuery"
        ],
        "type=plsqlFunctionBody": [
          "plsqlFunctionBody"
        ],
        "type=javaScriptExpression": [
          "javaScriptExpression"
        ],
        "type=static": [
          "value"
        ]
      },
      "severity": "error",
      "message": "setValue requires a matching payload setting for its selected type."
    },
    {
      "id": "DA_RULE_004",
      "scope": "dynamicAction.action",
      "forbidValues": {
        "action": [
          "executeJavaScriptCode"
        ]
      },
      "severity": "error",
      "message": "Use action executeJsCode instead of executeJavaScriptCode."
    },
    {
      "id": "DA_RULE_005",
      "scope": "dynamicAction.action.settings",
      "when": {
        "action": "executeJsCode"
      },
      "require": [
        "jsCode"
      ],
      "forbid": [
        "code"
      ],
      "severity": "error",
      "message": "executeJsCode must use settings.jsCode and must not use settings.code."
    },
    {
      "id": "DA_RULE_006",
      "scope": "dynamicAction.when",
      "when": {
        "selectionType": "button"
      },
      "require": [
        "button"
      ],
      "requirePattern": {
        "button": "^@[a-z0-9-]+$"
      },
      "severity": "error",
      "message": "Dynamic action button selectors must use button aliases (for example @cancel-claim)."
    },
    {
      "id": "DA_RULE_007",
      "scope": "dynamicAction.when",
      "when": {
        "selectionType": "button"
      },
      "forbidPattern": {
        "button": "^[A-Za-z0-9_-]+$"
      },
      "severity": "error",
      "message": "Do not use raw button names in dynamic actions. Use @<button-static-id>."
    },
    {
      "id": "DA_RULE_008",
      "scope": "dynamicAction.action.execution",
      "require": [
        "fireOnInit"
      ],
      "severity": "error",
      "message": "Dynamic action action.execution must set fireOnInit explicitly."
    },
    {
      "id": "DA_RULE_009",
      "scope": "dynamicAction.action.execution",
      "when": {
        "fireOnInit": true
      },
      "requiresContext": [
        "explicit_init_request"
      ],
      "severity": "error",
      "message": "fireOnInit must be false by default. Use true only when explicitly requested by the prompt."
    },
    {
      "id": "CONTENT_ROW_RULE_001",
      "scope": "region.contentRow.plugin-badge",
      "allowValues": {
        "position": [
          "start",
          "end"
        ]
      },
      "severity": "error",
      "message": "Content Row badge position must be one of start or end."
    },
    {
      "id": "REGION_RULE_001",
      "scope": "region.source",
      "forbidValues": {
        "type": [
          "Static"
        ]
      },
      "severity": "error",
      "message": "Data-backed APEXlang regions must use Table, View, or SQL sources; use static-content templates for static UI sections."
    },
    {
      "id": "REGION_RULE_002",
      "scope": "region.source.sql",
      "when": {
        "type": "SQL"
      },
      "forbid": [
        "name"
      ],
      "severity": "error",
      "message": "SQL data sources must not emit a data-source object name."
    },
    {
      "id": "REGION_RULE_003",
      "scope": "region.source.tableView",
      "whenAny": [
        {
          "type": "Table"
        },
        {
          "type": "View"
        }
      ],
      "require": [
        "name"
      ],
      "severity": "error",
      "message": "Table and View data sources must name a verified schema object."
    },
    {
      "id": "REGION_RULE_004",
      "scope": "region.position",
      "when": {
        "position": "breadcrumb-bar"
      },
      "requireValues": {
        "regionType": [
          "Classic Report"
        ],
        "qualifier": [
          "Contextual Info"
        ]
      },
      "forbidValues": {
        "pageMode": [
          "modalDialog"
        ]
      },
      "severity": "error",
      "message": "breadcrumb-bar is reserved for non-modal Contextual Info Classic Report regions."
    },
    {
      "id": "REGION_RULE_005",
      "scope": "region.classicReport.contextualInfo",
      "when": {
        "regionType": "Classic Report",
        "qualifier": "Contextual Info"
      },
      "requireValues": {
        "source.type": [
          "SQL"
        ]
      },
      "requiresContext": [
        "single_effective_row"
      ],
      "severity": "error",
      "message": "Contextual Info Classic Reports require SQL source and one effective row for the active context."
    },
    {
      "id": "REGION_RULE_006",
      "scope": "region.metricChart.interactions",
      "whenAny": [
        {
          "regionType": "Metric Card"
        },
        {
          "regionType": "Chart"
        }
      ],
      "forbid": [
        "links",
        "actions"
      ],
      "severity": "error",
      "message": "Metric Card and Chart regions must not own links or actions; model navigation through adjacent components."
    },
    {
      "id": "REGION_RULE_007",
      "scope": "region.cards.link",
      "when": {
        "regionType": "Cards",
        "linkType": "fullCard"
      },
      "forbid": [
        "label"
      ],
      "severity": "error",
      "message": "Cards fullCard links must not emit a label."
    },
    {
      "id": "REGION_RULE_008",
      "scope": "region.cards.link",
      "when": {
        "regionType": "Cards",
        "linkType": "button"
      },
      "require": [
        "label"
      ],
      "severity": "error",
      "message": "Cards button links must emit a concise label."
    },
    {
      "id": "REGION_RULE_009",
      "scope": "region.cards.action",
      "when": {
        "regionType": "Cards"
      },
      "require": [
        "label",
        "behavior.target"
      ],
      "forbid": [
        "position",
        "process"
      ],
      "severity": "error",
      "message": "Native Cards actions are row navigation actions using label plus declarative behavior.target; they must not emit position or attach processes directly."
    },
    {
      "id": "REGION_RULE_010",
      "scope": "region.list",
      "when": {
        "regionType": "List"
      },
      "require": [
        "qualifier"
      ],
      "forbid": [
        "source",
        "filters",
        "hiddenPageItems",
        "columns",
        "links",
        "actions"
      ],
      "severity": "error",
      "message": "List regions are navigation-only and must not emit data-backed region blocks."
    },
    {
      "id": "REGION_RULE_011",
      "scope": "region.filters",
      "allowRegionTypes": [
        "Faceted Search",
        "Smart Filters"
      ],
      "forbidOnFilterRegions": [
        "columns"
      ],
      "severity": "error",
      "message": "Only Faceted Search and Smart Filters regions may emit filters, and filter regions must not emit columns."
    },
    {
      "id": "REGION_RULE_012",
      "scope": "region.filter.name",
      "requirePattern": {
        "name": "^P[0-9]+_F_[A-Z][A-Z0-9_]*(_[0-9]+)?$"
      },
      "forbidPattern": {
        "name": "(_FROM|_TO)$"
      },
      "severity": "error",
      "message": "Filter names must use P{page}_F_{UPPER_DB_COLUMN}; range filter _FROM/_TO item pairs are not canonical."
    },
    {
      "id": "REGION_RULE_013",
      "scope": "region.smartFilters.searchItem",
      "requirePattern": {
        "name": "^P[0-9]+_F_SEARCH(_[0-9]+)?$"
      },
      "forbidPattern": {
        "name": "^P[0-9]+_SEARCH$"
      },
      "severity": "error",
      "message": "Smart Filters generated search item names must use P{page}_F_SEARCH, with suffix only for real collisions."
    },
    {
      "id": "REGION_RULE_014",
      "scope": "region.column.blob",
      "allowRegionTypes": [
        "Form",
        "Cards",
        "Content Row",
        "Classic Report",
        "Interactive Report"
      ],
      "allowRenderAsByRegion": {
        "Form": [
          "fileUpload",
          "imageUpload",
          "displayImage"
        ],
        "Cards": [
          "displayImage"
        ],
        "Content Row": [
          "displayImage"
        ],
        "Classic Report": [
          "displayImage"
        ],
        "Interactive Report": [
          "displayImage"
        ]
      },
      "requireContext": [
        "primary_keys_for_lookup"
      ],
      "severity": "error",
      "message": "BLOB columns are supported only in approved region types/render roles and require primary keys for lookup."
    },
    {
      "id": "REGION_RULE_015",
      "scope": "region.column.blob.storage",
      "normalizeKeys": {
        "File Name Column": "Filename Column"
      },
      "conditionalAllow": {
        "File Types": {
          "regionType": [
            "Form"
          ],
          "renderAs": [
            "fileUpload",
            "imageUpload"
          ]
        },
        "Alt Text Column": {
          "renderAs": [
            "imageUpload",
            "displayImage"
          ]
        }
      },
      "severity": "error",
      "message": "BLOB storage keys and companions must match the approved upload/display contract."
    },
    {
      "id": "REGION_RULE_016",
      "scope": "region.sql.orderBy",
      "forbidOrderByRegionTypes": [
        "Content Row",
        "Metric Card",
        "Interactive Report",
        "Map",
        "Calendar"
      ],
      "allowOrderByRegionTypes": [
        "Chart"
      ],
      "severity": "error",
      "message": "SQL ORDER BY is forbidden for parser-wrapped region types except Chart; use supported region ordering instead."
    },
    {
      "id": "REGION_RULE_017",
      "scope": "region.comments",
      "require": [
        "comments"
      ],
      "forbidValuesCaseInsensitive": {
        "comments": [
          "todo",
          "tbd",
          "n/a",
          "none",
          "test",
          "placeholder",
          "lorem ipsum"
        ]
      },
      "severity": "warning",
      "message": "Region comments should be functional context cues and must not use placeholder text."
    },
    {
      "id": "REGION_RULE_018",
      "scope": "region.icon",
      "requirePattern": {
        "icon": "^fa-[A-Za-z0-9_-]+$"
      },
      "requiresContextWhenPresent": [
        "icon_allowlist_membership_when_allowlist_exists"
      ],
      "severity": "warning",
      "message": "Region, metric, menu, list, and link icons should use literal fa-* tokens and respect the active icon allowlist."
    },
    {
      "id": "SAVED_REPORT_RULE_001",
      "scope": "region.savedReport.settings",
      "require": [
        "appUser"
      ],
      "severity": "error",
      "message": "savedReport settings must include appUser parameter for public reports."
    }
  ]
}
